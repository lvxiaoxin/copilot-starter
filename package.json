{
  "name": "copilot-starter",
  "version": "0.1.1",
  "description": "A beautiful terminal UI for managing GitHub Copilot CLI sessions — start new or resume past conversations",
  "main": "index.js",
  "bin": {
    "copilot-starter": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test --test-force-exit \"test/*.test.js\"",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "github",
    "copilot",
    "copilot-cli",
    "tui",
    "terminal",
    "session",
    "resume",
    "ai",
    "ai-native",
    "developer-workflow",
    "local-first",
    "agentic-tooling"
  ],
  "author": "lvxin",
  "license": "MIT",
  "homepage": "https://github.com/lvxiaoxin/copilot-starter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvxiaoxin/copilot-starter.git"
  },
  "bugs": {
    "url": "https://github.com/lvxiaoxin/copilot-starter/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.js",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "blessed": "^0.1.81",
    "js-yaml": "^4.1.0"
  }
